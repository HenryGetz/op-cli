#!/bin/sh

set -eu

resolve_script_path() {
  script_path="$1"
  if command -v readlink >/dev/null 2>&1; then
    while [ -L "$script_path" ]; do
      link_target="$(readlink "$script_path")"
      case "$link_target" in
        /*)
          script_path="$link_target"
          ;;
        *)
          script_dir="$(dirname -- "$script_path")"
          script_path="$script_dir/$link_target"
          ;;
      esac
    done
  fi
  printf '%s\n' "$script_path"
}

script_path="$(resolve_script_path "$0")"
script_dir="$(CDPATH='' cd -- "$(dirname -- "$script_path")" && pwd -P)"

install_env="${OMNI_INSTALL_ENV:-$HOME/.config/omni/install.env}"
if [ -f "$install_env" ]; then
  # shellcheck disable=SC1090
  . "$install_env"
fi

setup_usage() {
  cat <<'EOF'
Usage: omni setup [--cli-root <path>] [--runtime-root <path>] [--uied-root <path>] [--python <path>] [--show] [--clear]

Writes persistent config to ~/.config/omni/install.env (or $OMNI_INSTALL_ENV).

Examples:
  omni setup --cli-root /path/to/op-cli --runtime-root /path/to/OmniParser --uied-root /path/to/UIED
  omni setup --show
  omni setup --clear
EOF
}

shell_escape_single() {
  printf "%s" "$1" | sed "s/'/'\"'\"'/g"
}

if [ "${1:-}" = "setup" ]; then
  shift

  setup_cli_root="${OMNI_CLI_ROOT:-}"
  setup_runtime_root="${OMNIPARSER_ROOT:-${OMNI_RUNTIME_ROOT:-}}"
  setup_uied_root="${UIED_ROOT:-}"
  setup_python="${OMNI_PYTHON:-}"
  setup_show=0
  setup_clear=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --cli-root)
        shift
        [ "$#" -gt 0 ] || { echo "omni setup: --cli-root requires a value" >&2; exit 1; }
        setup_cli_root="$1"
        ;;
      --runtime-root)
        shift
        [ "$#" -gt 0 ] || { echo "omni setup: --runtime-root requires a value" >&2; exit 1; }
        setup_runtime_root="$1"
        ;;
      --python)
        shift
        [ "$#" -gt 0 ] || { echo "omni setup: --python requires a value" >&2; exit 1; }
        setup_python="$1"
        ;;
      --uied-root)
        shift
        [ "$#" -gt 0 ] || { echo "omni setup: --uied-root requires a value" >&2; exit 1; }
        setup_uied_root="$1"
        ;;
      --show)
        setup_show=1
        ;;
      --clear)
        setup_clear=1
        ;;
      -h|--help)
        setup_usage
        exit 0
        ;;
      *)
        echo "omni setup: unknown option '$1'" >&2
        setup_usage >&2
        exit 1
        ;;
    esac
    shift
  done

  if [ "$setup_show" -eq 1 ]; then
    echo "install_env=$install_env"
    if [ -f "$install_env" ]; then
      cat "$install_env"
    else
      echo "(not configured)"
    fi
    exit 0
  fi

  if [ "$setup_clear" -eq 1 ]; then
    if [ -f "$install_env" ]; then
      rm -f "$install_env"
    fi
    echo "Cleared persistent config at $install_env"
    exit 0
  fi

  if [ -z "$setup_cli_root" ] || [ -z "$setup_runtime_root" ]; then
    echo "omni setup requires --cli-root and --runtime-root (or pre-set env values)." >&2
    exit 1
  fi

  setup_cli_root="$(cd "$setup_cli_root" 2>/dev/null && pwd -P || true)"
  setup_runtime_root="$(cd "$setup_runtime_root" 2>/dev/null && pwd -P || true)"

  if [ -z "$setup_cli_root" ] || [ ! -f "$setup_cli_root/cli/omni.py" ]; then
    echo "omni setup: invalid --cli-root (missing cli/omni.py)." >&2
    exit 1
  fi

  if [ -z "$setup_runtime_root" ] || [ ! -f "$setup_runtime_root/util/utils.py" ]; then
    echo "omni setup: invalid --runtime-root (missing util/utils.py)." >&2
    exit 1
  fi

  if [ -n "$setup_python" ]; then
    setup_python="$(cd "$(dirname "$setup_python")" 2>/dev/null && pwd -P)/$(basename "$setup_python")"
    if [ ! -x "$setup_python" ]; then
      echo "omni setup: invalid --python (not executable): $setup_python" >&2
      exit 1
    fi
  fi

  if [ -n "$setup_uied_root" ]; then
    setup_uied_root="$(cd "$setup_uied_root" 2>/dev/null && pwd -P || true)"
    if [ -z "$setup_uied_root" ] || [ ! -f "$setup_uied_root/detect_compo/ip_region_proposal.py" ] || [ ! -f "$setup_uied_root/detect_merge/merge.py" ]; then
      echo "omni setup: invalid --uied-root (missing detect_compo/ip_region_proposal.py or detect_merge/merge.py)." >&2
      exit 1
    fi
  fi

  install_dir="$(dirname "$install_env")"
  mkdir -p "$install_dir"

  escaped_cli="$(shell_escape_single "$setup_cli_root")"
  escaped_runtime="$(shell_escape_single "$setup_runtime_root")"

  {
    printf "OMNI_CLI_ROOT='%s'\n" "$escaped_cli"
    printf "OMNIPARSER_ROOT='%s'\n" "$escaped_runtime"
    if [ -n "$setup_uied_root" ]; then
      escaped_uied="$(shell_escape_single "$setup_uied_root")"
      printf "UIED_ROOT='%s'\n" "$escaped_uied"
    fi
    if [ -n "$setup_python" ]; then
      escaped_python="$(shell_escape_single "$setup_python")"
      printf "OMNI_PYTHON='%s'\n" "$escaped_python"
    fi
  } >"$install_env"

  echo "Saved persistent omni config to $install_env"
  echo "OMNI_CLI_ROOT=$setup_cli_root"
  echo "OMNIPARSER_ROOT=$setup_runtime_root"
  if [ -n "$setup_uied_root" ]; then
    echo "UIED_ROOT=$setup_uied_root"
  fi
  if [ -n "$setup_python" ]; then
    echo "OMNI_PYTHON=$setup_python"
  fi
  exit 0
fi

find_cli_root() {
  for candidate in "$@"; do
    [ -n "$candidate" ] || continue
    if [ -f "$candidate/cli/omni.py" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

find_runtime_root() {
  for candidate in "$@"; do
    [ -n "$candidate" ] || continue
    if [ -f "$candidate/util/utils.py" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

CLI_ROOT=""
if [ -n "${OMNI_CLI_ROOT:-}" ]; then
  CLI_ROOT="$(find_cli_root "$OMNI_CLI_ROOT" || true)"
fi

if [ -z "$CLI_ROOT" ] && [ -n "${OMNI_ROOT:-}" ]; then
  CLI_ROOT="$(find_cli_root "$OMNI_ROOT" || true)"
fi

if [ -z "$CLI_ROOT" ]; then
  CLI_ROOT="$(find_cli_root \
    "$script_dir/.." \
    "$script_dir/../OmniParser" \
    "$script_dir/../omni-parser/OmniParser" \
    "$HOME/ai/op-cli" \
    "$HOME/ai/omni-parser/OmniParser" \
    "$HOME/OmniParser" \
    "$HOME/src/OmniParser" \
    "$HOME/projects/OmniParser" \
    || true)"
fi

if [ -z "$CLI_ROOT" ]; then
  echo "omni: unable to locate CLI root (expected <root>/cli/omni.py)" >&2
  echo "Set OMNI_CLI_ROOT or OMNI_ROOT, or create $install_env with OMNI_CLI_ROOT=<path>." >&2
  exit 2
fi

CLI_ENTRY="$CLI_ROOT/cli/omni.py"

RUNTIME_ROOT=""
if [ -n "${OMNIPARSER_ROOT:-}" ]; then
  RUNTIME_ROOT="$(find_runtime_root "$OMNIPARSER_ROOT" || true)"
fi

if [ -z "$RUNTIME_ROOT" ] && [ -n "${OMNI_RUNTIME_ROOT:-}" ]; then
  RUNTIME_ROOT="$(find_runtime_root "$OMNI_RUNTIME_ROOT" || true)"
fi

if [ -z "$RUNTIME_ROOT" ]; then
  RUNTIME_ROOT="$(find_runtime_root \
    "$CLI_ROOT" \
    "$CLI_ROOT/../OmniParser" \
    "$CLI_ROOT/../omni-parser/OmniParser" \
    "$HOME/ai/omni-parser/OmniParser" \
    "$HOME/OmniParser" \
    "$HOME/src/OmniParser" \
    "$HOME/projects/OmniParser" \
    || true)"
fi

if [ -z "$RUNTIME_ROOT" ]; then
  echo "omni: unable to locate OmniParser runtime root (expected <root>/util/utils.py)" >&2
  echo "Set OMNIPARSER_ROOT (or OMNI_RUNTIME_ROOT) to your OmniParser install directory." >&2
  exit 2
fi

if [ -n "${OMNI_PYTHON:-}" ]; then
  PYTHON_BIN="$OMNI_PYTHON"
elif [ -n "${VIRTUAL_ENV:-}" ] && [ -x "$VIRTUAL_ENV/bin/python" ]; then
  PYTHON_BIN="$VIRTUAL_ENV/bin/python"
elif [ -n "${CONDA_PREFIX:-}" ] && [ -x "$CONDA_PREFIX/bin/python" ]; then
  PYTHON_BIN="$CONDA_PREFIX/bin/python"
elif [ -x "$RUNTIME_ROOT/.venv/bin/python" ]; then
  PYTHON_BIN="$RUNTIME_ROOT/.venv/bin/python"
elif [ -x "$CLI_ROOT/.venv/bin/python" ]; then
  PYTHON_BIN="$CLI_ROOT/.venv/bin/python"
elif [ -x "$HOME/miniconda3/envs/omniparser_cpu/bin/python" ]; then
  PYTHON_BIN="$HOME/miniconda3/envs/omniparser_cpu/bin/python"
elif [ -x "$HOME/miniconda3/envs/omni/bin/python" ]; then
  PYTHON_BIN="$HOME/miniconda3/envs/omni/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="$(command -v python3)"
elif command -v python >/dev/null 2>&1; then
  PYTHON_BIN="$(command -v python)"
else
  echo "omni: unable to find a usable Python interpreter" >&2
  exit 2
fi

if [ -z "${OMNI_MODEL_DIR:-}" ] && [ -d "$RUNTIME_ROOT/weights" ]; then
  export OMNI_MODEL_DIR="$RUNTIME_ROOT/weights"
fi

export OMNIPARSER_ROOT="$RUNTIME_ROOT"

if [ "$CLI_ROOT" = "$RUNTIME_ROOT" ]; then
  export PYTHONPATH="$CLI_ROOT${PYTHONPATH:+:$PYTHONPATH}"
else
  export PYTHONPATH="$CLI_ROOT:$RUNTIME_ROOT${PYTHONPATH:+:$PYTHONPATH}"
fi

exec "$PYTHON_BIN" "$CLI_ENTRY" "$@"
