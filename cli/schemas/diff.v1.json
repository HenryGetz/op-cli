{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://op-cli.local/schemas/diff.v1.json",
  "title": "omni diff response",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "request_id",
    "timestamp_utc",
    "status",
    "error",
    "warnings",
    "meta",
    "diff"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1"
    },
    "command": {
      "type": "string",
      "const": "diff"
    },
    "request_id": {
      "type": "string"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "error"
      ]
    },
    "error": {
      "type": [
        "object",
        "null"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "meta": {
      "type": "object",
      "required": [
        "command",
        "request_id",
        "timestamp_utc",
        "image_path",
        "image_width",
        "image_height",
        "processing_time_ms",
        "omniparser_version",
        "cli_version"
      ],
      "additionalProperties": true
    },
    "diff": {
      "type": "object",
      "required": [
        "removed_elements",
        "added_elements",
        "moved_or_resized",
        "similarity_score",
        "matched_pairs",
        "unchanged_pairs",
        "save_diff_path"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
