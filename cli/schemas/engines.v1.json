{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://op-cli.local/schemas/engines.v1.json",
  "title": "caliper engines response",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "request_id",
    "timestamp_utc",
    "status",
    "error",
    "warnings",
    "meta",
    "engines"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1"
    },
    "command": {
      "type": "string",
      "const": "engines"
    },
    "request_id": {
      "type": "string"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "error"
      ]
    },
    "error": {
      "type": [
        "object",
        "null"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "meta": {
      "type": "object",
      "required": [
        "command",
        "request_id",
        "timestamp_utc",
        "processing_time_ms",
        "omniparser_version",
        "cli_version"
      ],
      "additionalProperties": true
    },
    "engines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "display_name",
          "available"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "available": {
            "type": "boolean"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
