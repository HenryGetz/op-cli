{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://op-cli.local/schemas/measure.v1.json",
  "title": "caliper measure response",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "request_id",
    "timestamp_utc",
    "status",
    "error",
    "warnings",
    "meta",
    "measurement"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1"
    },
    "command": {
      "type": "string",
      "const": "measure"
    },
    "request_id": {
      "type": "string"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "error"
      ]
    },
    "error": {
      "type": [
        "object",
        "null"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "meta": {
      "type": "object",
      "required": [
        "command",
        "request_id",
        "timestamp_utc",
        "image_path",
        "image_width",
        "image_height",
        "processing_time_ms",
        "omniparser_version",
        "cli_version"
      ],
      "additionalProperties": true
    },
    "measurement": {
      "type": "object",
      "required": [
        "from",
        "to",
        "delta_px",
        "horizontal_distance_px",
        "vertical_distance_px",
        "euclidean_distance_px",
        "selected_axis",
        "selected_distance_px"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
